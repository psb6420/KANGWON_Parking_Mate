PORT=3001

# 공공데이터포털 서비스 키 (한국교통안전공단, 기상청, 한국관광공사 공통)
DATA_GO_KR_SERVICE_KEY=your_service_key_here

# Kakao Developers
KAKAO_REST_API_KEY=your_kakao_rest_key_here
KAKAO_JAVASCRIPT_KEY=your_kakao_js_key_here

# Google Gemini API (LLM 추천 이유 생성)
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite DB 경로
# Railway 볼륨 사용 시: /data/parking_mate.db
# 로컬 개발 시: 비워두면 자동으로 ./parking_mate.db 사용
DB_PATH=
